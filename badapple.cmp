#i rl
#i math
#i vec
#i str

st Prt {
    fl x
    fl y
    fl speed
    fl size
}

i_m {
    it sW = 600
    it sH = 450

    init_w(sW, sH, "Cmp++ Bad Apple Procedural Visualizer")
    set_fps(60)

    fl tm = 0.0f
    bl iv = fs

    v<Prt> sts
    ⟳ (it idx = 0; idx < 30; idx++) {
        sts.pb(Prt{
            sc<fl>(ran() % sW),
            sc<fl>(ran() % sH),
            sc<fl>((ran() % 8) + 4),
            sc<fl>((ran() % 3) + 2),
        })
    }

    ⟲ (!w_close()) {
        tm += dt()

        ? (tm > 12.0f) {
            tm = 0.0f
            iv = fs
        }

        draw_b()

        ? (tm < 2.5f) {
            bg_cls(WHT)

            fl aY = 100.0f + (tm * 120.0f)
            fl aS = 35.0f

            circ(sW / 2, aY, aS, BLK)
            circ(sW / 2 - 12, aY - 8, aS * 0.9f, BLK)
            circ(sW / 2 + 12, aY - 8, aS * 0.9f, BLK)

            ⟳ (it i = 0; i < 8; i++) {
                circ(sW / 2 + i * 2, aY - aS - i * 1.5f, 4.0f, BLK)
            }

            circ(sW / 2 + 14, aY - aS - 10, 6.0f, BLK)

            text("Nagareteku toki no naka de demo", sW / 2 - 140, sH - 50, 18, DKGY)

        } | ? (tm >= 2.5f && tm < 3.0f) {
            iv = tr
            bg_cls(BLK)

            fl t = (tm - 2.5f) * 2.0f
            circ(sW / 2, sH / 2, t * 400.0f, WHT)

            ⟳ (it i = 0; i < 8; i++) {
                fl angle = i * 45.0f * (3.14159f / 180.0f)
                fl endX = sW / 2 + cos(angle) * (t * 500.0f)
                fl endY = sH / 2 + sin(angle) * (t * 500.0f)
                line(Vector2{sc<fl>(sW / 2), sc<fl>(sH / 2)}, Vector2{endX, endY}, 3.0f, BLK)
            }

        } | ? (tm >= 3.0f && tm < 6.5f) {
            bg_cls(BLK)

            fl yyX = 150.0f
            fl yyY = 220.0f
            fl yyR = 90.0f
            fl rot = tm * 2.0f

            circ(yyX, yyY, yyR, DKGY)
            sect(Vector2{yyX, yyY}, yyR, rot * (180.0f/3.14f), (rot + 3.14159f) * (180.0f/3.14f), 0, LTGY)
            circ(yyX + cos(rot)*yyR/2, yyY + sin(rot)*yyR/2, yyR/2, LTGY)
            circ(yyX + cos(rot+3.14f)*yyR/2, yyY + sin(rot+3.14f)*yyR/2, yyR/2, DKGY)
            circ(yyX + cos(rot)*yyR/2, yyY + sin(rot)*yyR/2, 8.0f, DKGY)
            circ(yyX + cos(rot+3.14f)*yyR/2, yyY + sin(rot+3.14f)*yyR/2, 8.0f, LTGY)

            fl rX = 400.0f
            fl rY = 250.0f

            rect(rX - 80, rY - 60, 45, 30, WHT)
            rect(rX - 80, rY - 30, 30, 45, WHT)

            rect(rX - 60, rY - 20, 50, 110, WHT)
            tri(Vector2{rX - 50, rY + 80}, Vector2{rX - 70, rY + 120}, Vector2{rX - 10, rY + 80}, WHT)

            circ(rX - 15, rY - 10, 40, WHT)
            tri(Vector2{rX - 15, rY + 25}, Vector2{rX + 25, rY - 10}, Vector2{rX + 15, rY + 20}, WHT)

            circ(rX + 15, rY + 45, 12, WHT)

            rect(rX - 50, rY + 50, 80, 120, WHT)

            text("Kedarusage hora guruguru mawatte", sW / 2 - 165, sH - 50, 18, LTGY)

        } | {
            bg_cls(BLK)

            ⟳ (auto& star : sts) {
                star.x -= star.speed
                ? (star.x < -10) {
                    star.x = sW + 10
                    star.y = ran() % sH
                }
                rect(star.x, star.y, star.size, star.size, WHT)
            }

            fl mX = 250.0f
            fl mY = 200.0f + sin(tm * 6.0f) * 18.0f

            line(Vector2{mX - 130, mY + 60}, Vector2{mX + 130, mY + 20}, 6.0f, WHT)
            tri(Vector2{mX - 110, mY + 55}, Vector2{mX - 170, mY + 80}, Vector2{mX - 160, mY + 40}, WHT)

            tri(Vector2{mX, mY - 60}, Vector2{mX - 35, mY - 10}, Vector2{mX + 35, mY - 10}, WHT)
            rect(mX - 45, mY - 12, 90, 8, WHT)

            circ(mX, mY + 15, 25, WHT)

            rect(mX - 25, mY + 15, 45, 55, WHT)

            tri(Vector2{mX - 30, mY + 110}, Vector2{mX, mY + 45}, Vector2{mX + 25, mY + 110}, WHT)
            rect(mX - 20, mY + 50, 45, 50, WHT)

            text("Watashi no kokoro mo shinteyuku no ka na", sW / 2 - 180, sH - 50, 18, LTGY)
        }

        rect(0, sH - 70, sW, 4, iv ? WHT : BLK)
        text("BAD APPLE!! - Cmp++ Graphic Demo", 15, 15, 14, GRAY)

        draw_e()
    }

    → 0
}
