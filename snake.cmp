#i rl
#i vec
#i cstd
#i chr

struct Segment {
    int x
    int y
}

i_m {
    int screenW = 800
    int screenH = 600
    int grid = 20

    init_w(screenW, screenH, "Cmp++ Snake Game")
    set_fps(60)

    #Game variables
    v<Segment> snake
    snake.pb(Segment{20, 15})
    snake.pb(Segment{19, 15})
    snake.pb(Segment{18, 15})

    int dirX = 1
    int dirY = 0

    #Spawn food
    int foodX = 5
    int foodY = 5

    int score = 0
    bool gameOver = false
    int frames = 0

    ⟲ (!w_close()) {
        ? (!gameOver) {
            frames++

            #Handle inputs
            ? (key_p(KEY_RIGHT) && dirX != -1) { dirX = 1; dirY = 0; }
            ? (key_p(KEY_LEFT) && dirX != 1) { dirX = -1; dirY = 0; }
            ? (key_p(KEY_UP) && dirY != 1) { dirX = 0; dirY = -1; }
            ? (key_p(KEY_DOWN) && dirY != -1) { dirX = 0; dirY = 1; }

            #Update position every 6 frames (speed control)
            ? (frames >= 6) {
                frames = 0

                #Move body
                ⟳ (int idx = snake.size() - 1; idx > 0; idx--) {
                    snake[idx] = snake[idx - 1]
                }

                #Move head
                snake[0].x += dirX
                snake[0].y += dirY

                #Wall collision
                ? (snake[0].x < 0 || snake[0].x >= screenW / grid || snake[0].y < 0 || snake[0].y >= screenH / grid) {
                    gameOver = true
                }

                #Self collision
                ⟳ (int idx = 1; idx < snake.size(); idx++) {
                    ? (snake[0].x == snake[idx].x && snake[0].y == snake[idx].y) {
                        gameOver = true
                    }
                }

                #Food collision
                ? (snake[0].x == foodX && snake[0].y == foodY) {
                    score += 10

                    #Grow snake
                    snake.pb(Segment{snake.back().x, snake.back().y})

                    #Randomize food position
                    foodX = ran() % (screenW / grid)
                    foodY = ran() % (screenH / grid)
                }
            }
        } | {
            #Restart game on space press
            ? (key_p(KEY_SPACE)) {
                snake.clear()
                snake.pb(Segment{20, 15})
                snake.pb(Segment{19, 15})
                snake.pb(Segment{18, 15})
                dirX = 1
                dirY = 0
                score = 0
                gameOver = false
                frames = 0
                foodX = ran() % (screenW / grid)
                foodY = ran() % (screenH / grid)
            }
        }

        #Drawing
        draw_b()
        bg_cls(BLACK)

        #Draw grid board borders
        rect(0, 0, screenW, 5, DARKGRAY)
        rect(0, 0, 5, screenH, DARKGRAY)
        rect(0, screenH - 5, screenW, 5, DARKGRAY)
        rect(screenW - 5, 0, 5, screenH, DARKGRAY)

        #Draw Snake
        ⟳ (const auto& seg : snake) {
            rect(seg.x * grid, seg.y * grid, grid - 1, grid - 1, GREEN)
        }

        #Draw head distinctly
        rect(snake[0].x * grid, snake[0].y * grid, grid - 1, grid - 1, LIME)

        #Draw Food
        rect(foodX * grid, foodY * grid, grid - 1, grid - 1, RED)

        #Draw HUD info
        str scoreText = "Score: " + to_str(score)
        text(scoreText.c_str(), 15, 15, 20, WHITE)

        ? (gameOver) {
            rect(screenW / 2 - 200, screenH / 2 - 80, 400, 160, fade(BLACK, 0.8f))
            text("GAME OVER", screenW / 2 - 100, screenH / 2 - 50, 40, RED)
            text("Press SPACE to Restart", screenW / 2 - 150, screenH / 2 + 10, 20, WHITE)
        }

        draw_e()
    }

    → 0
}
