#i rl
#i vec
#i cstd
#i chr

st Seg {
    it x
    it y
}

i_m {
    it sW = 800
    it sH = 600
    it gd = 20

    init_w(sW, sH, "Cmp++ Snake Game")
    set_fps(60)

    v<Seg> snk
    snk.pb(Seg{20, 15})
    snk.pb(Seg{19, 15})
    snk.pb(Seg{18, 15})

    it dX = 1
    it dY = 0

    it fX = 5
    it fY = 5

    it scr = 0
    bl gO = fs
    it fr = 0

    ⟲ (!w_close()) {
        ? (!gO) {
            fr++

            ? (key_p(K_R) && dX != -1) { dX = 1; dY = 0; }
            ? (key_p(K_L) && dX != 1) { dX = -1; dY = 0; }
            ? (key_p(K_U) && dY != 1) { dX = 0; dY = -1; }
            ? (key_p(K_D) && dY != -1) { dX = 0; dY = 1; }

            ? (fr >= 6) {
                fr = 0

                ⟳ (it idx = snk.size() - 1; idx > 0; idx--) {
                    snk[idx] = snk[idx - 1]
                }

                snk[0].x += dX
                snk[0].y += dY

                ? (snk[0].x < 0 || snk[0].x >= sW / gd || snk[0].y < 0 || snk[0].y >= sH / gd) {
                    gO = tr
                }

                ⟳ (it idx = 1; idx < snk.size(); idx++) {
                    ? (snk[0].x == snk[idx].x && snk[0].y == snk[idx].y) {
                        gO = tr
                    }
                }

                ? (snk[0].x == fX && snk[0].y == fY) {
                    scr += 10

                    snk.pb(Seg{snk.back().x, snk.back().y})

                    fX = ran() % (sW / gd)
                    fY = ran() % (sH / gd)
                }
            }
        } | {
            ? (key_p(K_S)) {
                snk.clear()
                snk.pb(Seg{20, 15})
                snk.pb(Seg{19, 15})
                snk.pb(Seg{18, 15})
                dX = 1
                dY = 0
                scr = 0
                gO = fs
                fr = 0
                fX = ran() % (sW / gd)
                fY = ran() % (sH / gd)
            }
        }

        draw_b()
        bg_cls(BLK)

        rect(0, 0, sW, 5, DKGY)
        rect(0, 0, 5, sH, DKGY)
        rect(0, sH - 5, sW, 5, DKGY)
        rect(sW - 5, 0, 5, sH, DKGY)

        ⟳ (const auto& seg : snk) {
            rect(seg.x * gd, seg.y * gd, gd - 1, gd - 1, GRN)
        }

        rect(snk[0].x * gd, snk[0].y * gd, gd - 1, gd - 1, LIM)

        rect(fX * gd, fY * gd, gd - 1, gd - 1, RED)

        str sT = "Score: " + to_str(scr)
        text(sT.c_str(), 15, 15, 20, WHT)

        ? (gO) {
            rect(sW / 2 - 200, sH / 2 - 80, 400, 160, fade(BLK, 0.8f))
            text("GAME OVER", sW / 2 - 100, sH / 2 - 50, 40, RED)
            text("Press SPACE to Restart", sW / 2 - 150, sH / 2 + 10, 20, WHT)
        }

        draw_e()
    }

    → 0
}
